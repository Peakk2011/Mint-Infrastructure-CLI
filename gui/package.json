{
  "name": "mint-infrastructure-gui",
  "version": "1.0.0",
  "description": "Desktop GUI for the Mint Infrastructure Markdown-to-HTML compiler.",
  "main": "dist/main.js",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,cts}\"",
    "test": "npm run build:ts && node --test tests/convert-process.test.mjs",

    "build:ts": "tsc",
    "build:renderer:win": "npm run build:ts && npm run sync:renderer",
    "build:renderer:mac": "npm run build:ts && npm run sync:renderer:mac",

    "sync:mintif": "powershell -ExecutionPolicy Bypass -File scripts/sync-mintif.ps1",
    "sync:mintif:mac": "bash scripts/sync-mintif.sh",
    "sync:renderer": "powershell -ExecutionPolicy Bypass -File scripts/sync-renderer-assets.ps1",
    "sync:renderer:mac": "bash scripts/sync-renderer-assets.sh",

    "dev": "npm run build:renderer:win && node scripts/start-electron.mjs",
    "dev:mac": "npm run build:renderer:mac && node scripts/start-electron.mjs",
    "start": "node scripts/start-electron.mjs",

    "package:win": "npm run sync:mintif && npm run build:renderer:win && electron-builder --win --publish never",
    "package:mac": "npm run sync:mintif:mac && npm run build:renderer:mac && electron-builder --mac --publish never"
  },
  "keywords": [
    "markdown",
    "electron",
    "desktop",
    "mintif"
  ],
  "author": "Mint Teams",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^25.2.2",
    "electron": "^40.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.20.1",
    "typescript-eslint": "^8.24.1",
    "typescript": "^5.9.2"
  },
  "build": {
    "appId": "com.mint.infrastructure.gui",
    "productName": "Mint Infrastructure GUI",
    "icon": "assets/logo/Mintif Logo.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/win-unpacked{,/**}",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "!dist/*.7z",
      "!dist/builder-debug.yml",
      "!dist/builder-effective-config.yaml",
      "!dist/**/*.map",
      "!dist/**/*.d.ts",
      "!dist/**/*.d.cts",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/mintif",
        "to": "mintif",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bindings/build/Release",
        "to": "darling",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [],
    "win": {
      "icon": "assets/logo/Mintif Logo.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/logo/Mintif Logo.ico",
      "uninstallerIcon": "assets/logo/Mintif Logo.ico",
      "installerHeaderIcon": "assets/logo/Mintif Logo.ico"
    }
  }
}
